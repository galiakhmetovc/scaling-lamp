# Clean-room runtime environment

# Autoloaded automatically from ./.env by cmd/agent if the process environment
# does not already define the variable.
# Required for live z.ai smoke and provider calls.
TEAMD_ZAI_API_KEY=replace-with-real-key

# Optional override for local smoke wrappers if you want a separate generic alias.
# ZAI_API_KEY=replace-with-real-key
