# Local agentd environment
#
# agentd now autoloads ./.env when explicit process environment variables are
# not already set.
#
# Baseline z.ai values below are taken from the existing smoke selections in the
# other project branches:
# - base URL: https://api.z.ai/api/coding/paas/v4
# - model:    glm-5-turbo

TEAMD_PROVIDER_KIND=zai_chat_completions
TEAMD_PROVIDER_API_BASE=https://api.z.ai/api/coding/paas/v4
TEAMD_PROVIDER_MODEL=glm-5-turbo
TEAMD_PERMISSION_MODE=default

TEAMD_PROVIDER_API_KEY=replace-with-real-key

# Optional provider runtime limits.
# Defaults:
# - connect timeout: 15 seconds
# - overall request timeout: disabled
# - stream idle timeout: 1200 seconds
# - max output tokens: omitted from requests
#
# TEAMD_PROVIDER_CONNECT_TIMEOUT_SECONDS=15
# TEAMD_PROVIDER_REQUEST_TIMEOUT_SECONDS=
# TEAMD_PROVIDER_STREAM_IDLE_TIMEOUT_SECONDS=1200
# TEAMD_PROVIDER_MAX_OUTPUT_TOKENS=
